<script type="application/json" data-nuxt-data="nuxt-app" data-ssr="true" id="__NUXT_DATA__">[["ShallowReactive",1],{"data":2,"state":1081,"once":1084,"_errors":1085,"serverRendered":9,"path":1088,"pinia":1089},["ShallowReactive",3],{"index":4},{"pageType":5,"isLoading":6,"context":7,"user":81,"page":83},"Maker",false,{"siteName":8,"isDesignCom":9,"isUserAuthenticated":9,"theme":10,"brandCrowdBranding":11,"brandCrowdEnvironment":12,"resource":13,"head":17,"isNotBrandCrowdOrigin":9,"brazeConfig":59,"raygunConfig":62,"googleTagManagerConfig":66,"smartlingVisualContextConfig":68,"mixpanelConfig":70,"cookie":76,"userTermsAgreement":78,"sessionId":75,"isMultiLingualEnabled":9,"isFrenchAndBrazillianLanguagesEnabled":9,"requestCountry":79,"datadogSessionSampleRate":80,"datadogSessionReplaySampleRate":80,"initialiseFoundationScript":9,"includeLogoTemplateProductMeta":9},"Design.com",true,"bc","Dcom","Prod",{"tailwindCssPath":14,"fontRefs":15},"/dist/css/tailwind-designCom.css?v=JBQHQuizrvwEfs9sFnQRsaM6f1SNWuR3rOmpg1DEuSs",[16],"https://bcassetcdn.com/fonts/inter.woff2",{"title":18,"metas":19,"links":23,"scripts":44},"Mental Health Support Logo | Design.com Logo Maker | Design.com",[20],{"name":21,"content":22},"Description","Introducing the Mindful Mental Wellness logo, a visual embodiment of holistic health and support for the mind. This thoughtfully designed emblem encapsulates the essence of wellness and rehabilitation, merging elements of psychology, neurology, and therapy. The logo features a serene mind motif, symbolizing clarity and balance, intertwined with subtle imagery representing memory and cognitive strength. Each aspect reflects our commitment to fostering psychological resilience through compassionate counseling and rehabilitation. Whether you’re seeking guidance from a psychologist, neurologist, psychiatrist, or life coach, our logo serves as a beacon of hope and support on your mental wellness journey. It represents a safe space for healing, growth, and empowerment, inviting individuals to embrace their full potential and break through mental barriers. Experience a supportive community dedicated to nurturing your mind with Mindful Mental Wellness.",[24,28,31,35,38,41],{"key":25,"rel":26,"href":27,"async":9},"app-bc-dcom-css","stylesheet","https://dcstatic.com/css/app-bc-dcom-CB323.css",{"key":29,"rel":26,"href":30,"async":9},"maker-css","/dist/css/library.app-maker-designCom.min.css?v=BD4fMtQphI1T7gQ_YLkr0w3XHzf2VlrEkF1ZkokQNi0",{"rel":32,"href":33,"async":6,"sizes":34},"icon","https://bcassetcdn.com/favicon/dcom-production/favicon.ico","32x32",{"rel":32,"href":36,"async":6,"type":37},"https://bcassetcdn.com/favicon/dcom-production/icon.svg","image/svg+xml",{"rel":39,"href":40,"async":6},"apple-touch-icon","https://bcassetcdn.com/favicon/dcom-production/apple-touch-icon.png",{"rel":42,"href":43},"canonical","https://www.design.com/maker/logo/mental-health-support-698178/details",[45,47,49,51,53,55,57],{"src":46},"https://polyfill-fastly.io/v3/polyfill.js?features=Array.prototype.find,Promise&rum=0",{"src":48},"/maker/assets/js/jquery-3.3.1.min.js?v=160a426ff2894252cd7cebbdd6d6b7da8fcd319c65b70468f10b6690c45d02ef",{"src":50},"/maker/assets/js/foundation.min.js?v=5942879cbac8af1f1d7b0fff22948498f37f353dc318012621e3d06081092cbb",{"src":52},"/maker/assets/js/tt-util.js?v=093ca1ee0d9d80515cc302144e771ad0fe4ba466f40e84a4879f0cb161f92201",{"src":54},"/maker/assets/js/bc.marketing.js?v=f59e01ee24bb3aeb11e2dcaa653e03e3bbea427af075edde4489b8b00906c8da",{"src":56},"/maker/assets/js/bc.load-fabric-image.js?v=beda7321531f63b44daad91845e78e3540ca3829f41e3133a36b0a61352551a8",{"src":58},"/maker/assets/js/designReferrerHelper.js?v=0f684dc714590adcf29c27365ee41b97afaa4c55c04eb3f327a0536535a0fab8",{"publicApiKey":60,"baseUrl":61},"10402dcf-98a1-474c-92da-ec52a09a8616","https://sdk.iad-03.braze.com/api/v3",{"useRaygunJsClient":6,"useRaygunErrorHandlerForVue":9,"jsKey":63,"makerJsKey":64,"websiteMakerJsKey":65},"elzVocbxq2qv90vcLA5Uwg",