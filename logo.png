window.vueErrorHandler = function (error, customData, tags, whitelistError) {
  if(!!customData && typeof customData === 'object') {
    customData['requestCountry'] = 'IN';
  }

  const tagList = Array.isArray(tags)
    ? tags.filter(t => typeof t === 'string')
    : (typeof tags === 'string' ? [tags] : []);

  const errorMessage = typeof error === 'object' && error.hasOwnProperty('message') ? error.message : '';
  const blacklistPatterns = [
    'Script error',
    'dynamically imported module',
    'Importing a module script failed.',
    'Failed to fetch',
    'No response',
    'Load failed',
    'Service Unavailable',
    '404'
  ]
  const blacklistTags = ['chunk-error'];

  const patternBlacklisted = blacklistPatterns.some(pattern =>
    errorMessage.includes(pattern)
  );
  const tagBlacklisted = tagList.some(tag => blacklistTags.includes(tag));
  const blacklistError = patternBlacklisted || tagBlacklisted;

  try {
    if (blacklistError && !whitelistError) {
      console && console.warn('Skipping error logging', {error, tags: tagList});
    } else if (true || whitelistError) {
      rg4js('send', { error, tags: tagList, customData })
    }
  } catch { /* swallow */ }
};</script>
